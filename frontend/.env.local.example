# URL backend PHP (tanpa trailing slash)
NEXT_PUBLIC_API_URL=https://api.boarding.rotibakarngeunah.my.id

# Untuk development lokal:
# NEXT_PUBLIC_API_URL=http://localhost:8000

# Harus SAMA dengan JWT_SECRET di backend (dipakai middleware untuk verifikasi cookie)
JWT_SECRET=sama_dengan_backend_jwt_secret

# Base URL frontend (untuk membuat link onboarding yang bisa di-copy admin)
NEXT_PUBLIC_APP_URL=https://boarding.rotibakarngeunah.my.id
